{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt && python scripts/train_model.py",
  "installCommand": "pip install -r requirements.txt",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
